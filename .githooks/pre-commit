#!/bin/bash
set -e

echo "Tidy Go modules..."
go mod tidy

# Get staged .go files only
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -n "$STAGED_GO_FILES" ]; then
  echo "Linting staged files with golangci-lint..."
  golangci-lint run --config .golangci.yml --fix $STAGED_GO_FILES

  # Re-stage only the originally staged files (lint may have auto-fixed them)
  git add $STAGED_GO_FILES
else
  echo "No staged .go files to lint."
fi

# Re-stage go.mod / go.sum if tidy changed them
git add go.mod go.sum 2>/dev/null || true

echo "Running tests..."
make gen-mock
make test
echo "All tests passed!"
